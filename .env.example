# Slack (get from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PATH=./chroma_db

# Grok (xAI) — set GROK_ENABLED=true and add your API key to use Grok as primary LLM
# Get your key at: https://console.x.ai
GROK_ENABLED=false
GROK_API_KEY=xai-your-key-here
GROK_MODEL=grok-2-mini

# Grafana — set GRAFANA_ENABLED=true and fill in the values when you have them
GRAFANA_ENABLED=false
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-grafana-api-key
# Loki datasource UID - find it at Grafana > Connections > Data sources > Loki > copy UID from URL
GRAFANA_LOKI_UID=your-loki-datasource-uid

# Repos to index (comma-separated absolute paths)
REPO_PATHS=/Users/piyush.kumar/Rupeek-github-repos/rupeek-bazaar,/Users/piyush.kumar/Rupeek-github-repos/lead-service/lead-service,/Users/piyush.kumar/Rupeek-github-repos/image-service/image-service,/Users/piyush.kumar/Rupeek-github-repos/rupeek-quick
